<% content_for :title, "Todos" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Todos</h1>
  <%= link_to "New todo", new_todo_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
</div>

<div id="todos" class="space-y-4">
  <% @todos.each do |todo| %>
    <div class="bg-white p-4 rounded shadow">
      <%= render todo %>
      <div class="mt-2">
        <%= link_to "Show this todo", todo, class: "text-blue-600 hover:underline text-sm" %>
      </div>
    </div>
  <% end %>
</div>
