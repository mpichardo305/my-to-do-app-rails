<% content_for :title, "Editing todo" %>

<h1 class="text-2xl font-bold text-gray-800 mb-4">Editing todo</h1>

<%= render "form", todo: @todo %>

<div class="mt-4 flex items-center gap-4">
  <%= link_to "Show this todo", @todo, class: "text-blue-600 hover:underline" %>
