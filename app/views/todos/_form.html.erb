<%= form_with(model: todo, class: "bg-white p-6 rounded shadow space-y-4") do |form| %>
  <% if todo.errors.any? %>
    <div class="bg-red-100 text-red-800 p-4 rounded">
      <h2 class="font-semibold mb-2"><%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:</h2>
      <ul class="list-disc list-inside">
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.textarea :description, class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", rows: 4 %>
  </div>

  <div class="flex items-center gap-2">
    <%= form.checkbox :completed, class: "rounded border-gray-300" %>
    <%= form.label :completed, class: "text-sm font-medium text-gray-700" %>
  </div>

  <div>
    <%= form.label :priority, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.number_field :priority, class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.label :project_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.collection_select :project_id, Project.all, :id, :name, { prompt: "Select a project" }, { class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" } %>
  </div>

  <div>
    <%= form.submit class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
