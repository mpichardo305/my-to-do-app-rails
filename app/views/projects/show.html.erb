<h1 class="text-2xl font-bold text-gray-800 mb-2"><%= @project.name %></h1>

<h2 class="text-xl font-semibold text-gray-700 mb-4">Todos for this project</h2>

<ul class="space-y-2 mb-6">
  <% @project.todos.each do |todo| %>
    <li class="bg-white p-4 shadow rounded flex items-center justify-between">
      <span class="text-gray-800"><%= todo.name %></span>
      <% if todo.completed %>
        <span class="text-green-600 font-bold">Done</span>
      <% end %>
    </li>
  <% end %>
</ul>

<div class="flex items-center gap-4">
  <%= link_to "Edit this project", edit_project_path(@project), class: "text-blue-600 hover:underline" %>
  <%= link_to "Back to projects", projects_path, class: "text-blue-600 hover:underline" %>
  <%= button_to "Destroy this project", project_path(@project), method: :delete, class: "bg-red-600 text-white px-3 py-1 rounded hover:bg-red-700" %>
</div>
